@model BankManagement.Models.account
@{
    ViewBag.Title = "Create Account";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    body {
        background-color: #FFCCFF;
    }

    .create-account-card {
        max-width: 550px;
        margin: 0 auto;
    }

    .form-label {
        font-weight: 600;
        color: #495057;
    }

    .page-heading {
        font-size: 2rem;
        font-weight: bold;
        color: #2c3e50;
    }

    .text-danger {
        font-size: 0.875rem;
    }

    .account-info {
        background-color: #e7f3ff;
        border-left: 4px solid #0d6efd;
        padding: 1rem;
        border-radius: 0.375rem;
        margin-bottom: 1.5rem;
    }

        .account-info h6 {
            color: #0d6efd;
            font-weight: bold;
            margin-bottom: 0.5rem;
        }

        .account-info p {
            color: #495057;
            font-size: 0.9rem;
            margin-bottom: 0;
        }

    @@media (max-width: 992px) {
        .page-heading {
            font-size: 1.75rem;
        }
    }

    @@media (max-width: 768px) {
        .page-heading {
            font-size: 1.5rem;
        }
    }

    @@media (max-width: 576px) {
        .page-heading {
            font-size: 1.25rem;
        }

        .btn {
            width: 100%;
        }

        .create-account-card {
            padding: 1rem !important;
        }
    }
</style>

<div class="container mt-5">

    <div class="card shadow p-4 create-account-card">
        <div class="account-info">
            <h6><i class="bi bi-info-circle"></i> Account Information</h6>
            <p>Please fill in the details below to create a New Bank Account. You can choose between Saving or Current account type.</p>
        </div>

        @using (Html.BeginForm("AccountCreate", "Account", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

            
            <div class="mb-3">
                <label for="accounttype" class="form-label">Account Type</label>
                @Html.DropDownListFor(m => m.accounttype,new SelectList(new[] { "Saving", "Current" }),"Select Account Type", new { @class = "form-control form-select" })
                @Html.ValidationMessageFor(m => m.accounttype, "", new { @class = "text-danger" })
            </div>

           
            <div class="mb-3">
                <label for="balance" class="form-label">Initial Balance</label>
                <div class="input-group">
                    <span class="input-group-text">₹</span>
                    @Html.TextBoxFor(m => m.balance, new { @class = "form-control", type = "number", step = "0.01", min = "0", placeholder = "Enter amount" })
                </div>
                @Html.ValidationMessageFor(m => m.balance, "", new { @class = "text-danger" })
                <small class="text-muted">Minimum balance: ₹500 for Saving, ₹1000 for Current</small>
            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-circle"></i> Create Account
                </button>
                <a href="@Url.Action("Dashboard", "Account")" class="btn btn-secondary">
                    Cancel
                </a>
            </div>
        }
    </div>
    <div class="card shadow mt-4 create-account-card">
        <div class="card-body">
            <h5 class="card-title">Account Types</h5>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <h6 class="text-primary">Saving Account</h6>
                    <ul class="small">
                        <li>Minimum balance: ₹500</li>
                        <li>Interest rate: 4% per annum</li>
                        <li>Ideal for personal savings</li>
                        <li>Limited transactions</li>
                    </ul>
                </div>
                <div class="col-md-6 mb-3">
                    <h6 class="text-success">Current Account</h6>
                    <ul class="small">
                        <li>Minimum balance: ₹1000</li>
                        <li>No interest</li>
                        <li>Ideal for business</li>
                        <li>Unlimited transactions</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}

