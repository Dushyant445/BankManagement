<h3>Transaction History</h3>

<table class="table table-bordered">
    <tr>
        <th>Date</th>
        <th>Type</th>
        <th>Amount</th>
        <th>Account No</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Date</td>
            <td>@item.Type</td>
            <td>@item.Amount</td>
            <td>@item.Account</td>
        </tr>
    }
</table>
